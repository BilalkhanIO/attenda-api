# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/attenda_db"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-this-to-a-long-random-secret-in-production"
JWT_REFRESH_SECRET="change-this-refresh-secret-too"
JWT_EXPIRES_IN="8h"
JWT_REFRESH_EXPIRES_IN="30d"

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"

# WhatsApp (Meta Cloud API)
WHATSAPP_PHONE_ID=""
WHATSAPP_TOKEN=""
WHATSAPP_VERIFY_TOKEN="attenda_webhook_verify"
WHATSAPP_APP_SECRET=""

# Anthropic Claude API (Remote check-in parsing)
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL=""              # Claude model for remote reply parsing (default: claude-sonnet-4-6)

# AWS S3 (Payslips + logos)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET="attenda-files"

# Email (Password reset)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@attenda.app"
