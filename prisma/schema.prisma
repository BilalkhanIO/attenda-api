generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organisation {
  id                 String   @id @default(uuid())
  name               String   @db.VarChar(255)
  logo_url           String?
  timezone           String   @db.VarChar(100)
  currency           String   @db.VarChar(10) @default("USD")
  office_ips         String[] @default([])
  office_ssids       String[] @default([])
  wa_enabled         Boolean  @default(false)
  wa_phone_number_id String?
  wa_access_token    String?
  wa_groups          Json     @default("[]")
  wa_events          Json     @default("{}")
  wa_dept_groups     Json     @default("{}")
  payroll_day        Int      @default(28)
  tax_rate           Float    @default(0)
  pension_rate       Float    @default(0)
  late_threshold     Int      @default(15)
  plan               String   @db.VarChar(50) @default("trial")
  status             String   @db.VarChar(20) @default("active")
  subscription_status String  @db.VarChar(30) @default("active")
  trial_started_at   DateTime?
  trial_ends_at      DateTime?
  seats_limit        Int?
  features_override  Json?
  admin_notes        String?  @db.Text
  billing_email      String?  @db.VarChar(255)
  contact_name       String?  @db.VarChar(255)
  contact_email      String?  @db.VarChar(255)
  company_size       String?  @db.VarChar(50)
  totp_required      Boolean  @default(false)
  created_at         DateTime @default(now())

  users               User[]
  attendance_records  AttendanceRecord[]
  leave_requests      LeaveRequest[]
  leave_balances      LeaveBalance[]
  shifts              Shift[]
  payroll_records     PayrollRecord[]
  whatsapp_logs       WhatsappLog[]
  performance_reviews PerformanceReview[]
  overtime_rules      OvertimeRule[]
  overtime_requests   OvertimeRequest[]
  notifications       InAppNotification[]
  late_arrival_notices LateArrivalNotice[]
  org_roles             OrgRole[]
  user_permission_grants UserPermissionGrant[]

  @@map("organisations")
}

model User {
  id             String    @id @default(uuid())
  org_id         String
  name           String    @db.VarChar(255)
  email          String    @unique @db.VarChar(255)
  password_hash  String
  role           String    @db.VarChar(50)
  department     String?   @db.VarChar(100)
  job_title      String?   @db.VarChar(100)
  phone          String?   @db.VarChar(30)
  manager_id     String?
  hourly_rate    Decimal   @default(0) @db.Decimal(10, 2)
  avatar_url     String?
  is_active      Boolean   @default(true)
  setup_complete Boolean   @default(false)
  invite_token   String?   @unique
  invite_expires DateTime?
  reset_token    String?   @unique
  reset_expires  DateTime?
  login_attempts Int       @default(0)
  locked_until   DateTime?
  totp_secret          String?
  totp_enabled         Boolean   @default(false)
  notification_prefs   Json      @default("{\"check_in\":true,\"leave_updates\":true,\"shift_reminders\":true,\"payroll\":true,\"announcements\":true,\"late_alerts\":true}")
  google_id            String?   @unique
  created_at     DateTime  @default(now())
  deleted_at     DateTime?

  org                     Organisation        @relation(fields: [org_id], references: [id])
  manager                 User?               @relation("UserManager", fields: [manager_id], references: [id])
  direct_reports          User[]              @relation("UserManager")
  attendance_records      AttendanceRecord[]
  leave_requests          LeaveRequest[]
  leave_balances          LeaveBalance[]
  reviewed_leaves         LeaveRequest[]      @relation("LeaveReviewer")
  shift_assignments       ShiftAssignment[]
  swap_requests_sent      ShiftSwap[]         @relation("SwapRequester")
  swap_requests_received  ShiftSwap[]         @relation("SwapTarget")
  payroll_records         PayrollRecord[]
  processed_payrolls      PayrollRecord[]     @relation("PayrollProcessor")
  performance_reviews     PerformanceReview[] @relation("ReviewSubject")
  submitted_reviews       PerformanceReview[] @relation("ReviewSubmitter")
  performance_goals       PerformanceGoal[]
  remote_sessions         RemoteSession[]
  notifications           InAppNotification[]
  late_arrival_notices    LateArrivalNotice[]
  overtime_requests       OvertimeRequest[]
  org_role_assignment     UserOrgRole?
  permission_grants       UserPermissionGrant[]
  platform_role_assignments PlatformUserRole[]

  @@map("users")
}

model AttendanceRecord {
  id              String    @id @default(uuid())
  user_id         String
  org_id          String
  date            DateTime  @db.Date
  check_in_at     DateTime?
  check_out_at    DateTime?
  check_in_type   String    @db.VarChar(20)
  status          String    @db.VarChar(20)
  hours_worked    Decimal?  @db.Decimal(5, 2)
  overtime_hours  Decimal   @default(0) @db.Decimal(5, 2)
  extra_office_minutes Int   @default(0)
  ip_detected     String?   @db.VarChar(50)
  is_overridden              Boolean   @default(false)
  override_by                String?
  override_reason            String?
  shift_id                   String?
  ip_checkout_pending_at     DateTime?
  created_at                 DateTime  @default(now())

  scheduled_start    DateTime?
  scheduled_end      DateTime?
  break_minutes      Int       @default(0)
  paid_break_minutes Int       @default(0)
  net_hours_worked   Decimal?  @db.Decimal(5, 2)
  late_minutes          Int       @default(0)
  early_out_minutes     Int       @default(0)
  early_checkin_minutes Int       @default(0)
  adherence_score    Int?
  auto_checked_out   Boolean   @default(false)
  late_alerted       Boolean   @default(false)
  hour_alerted       Boolean   @default(false)
  absent_alerted     Boolean   @default(false)
  late_notice_id     String?
  is_on_approved_leave Boolean @default(false)
  last_heartbeat_at    DateTime?
  last_heartbeat_ssid  String?   @db.VarChar(100)

  user           User               @relation(fields: [user_id], references: [id])
  org            Organisation       @relation(fields: [org_id], references: [id])
  shift          Shift?             @relation(fields: [shift_id], references: [id])
  late_notice    LateArrivalNotice? @relation(fields: [late_notice_id], references: [id], onDelete: SetNull)
  remote_session RemoteSession?
  break_records  BreakRecord[]
  overtime_request OvertimeRequest?

  @@unique([user_id, date])
  @@map("attendance_records")
}

model BreakRecord {
  id              String    @id @default(uuid())
  attendance_id   String
  break_start     DateTime
  break_end       DateTime?
  is_paid         Boolean   @default(false)
  break_type      String    @db.VarChar(50)
  duration_mins   Int?
  auto_ended      Boolean   @default(false)
  auto_started    Boolean   @default(false)
  shift_break_id  String?
  limit_exceeded  Boolean   @default(false)
  counted_as_extra Boolean  @default(false)
  source          String    @default("manual") @db.VarChar(30)
  late_return_minutes Int?
  wifi_on_at_end  Boolean   @default(false)

  attendance  AttendanceRecord @relation(fields: [attendance_id], references: [id], onDelete: Cascade)
  shift_break ShiftBreak?      @relation(fields: [shift_break_id], references: [id], onDelete: SetNull)

  @@map("break_records")
}

model RemoteSession {
  id               String    @id @default(uuid())
  attendance_id    String    @unique
  user_id          String
  approved_by      String?
  status           String    @default("pending")
  duration_type    String    @db.VarChar(20)
  morning_nudge_at DateTime?
  midday_nudge_at  DateTime?
  end_nudge_at     DateTime?
  ai_summary       String?
  created_at       DateTime  @default(now())

  attendance   AttendanceRecord   @relation(fields: [attendance_id], references: [id])
  user         User               @relation(fields: [user_id], references: [id])
  checkin_logs RemoteCheckinLog[]

  @@map("remote_sessions")
}

model RemoteCheckinLog {
  id                String    @id @default(uuid())
  remote_session_id String
  nudge_type        String    @db.VarChar(20)
  nudge_sent_at     DateTime
  reply_text        String?
  reply_at          DateTime?
  task_summary      String?
  blockers          String?
  sentiment         String?   @db.VarChar(20)
  no_reply_alerted  Boolean   @default(false)

  remote_session RemoteSession @relation(fields: [remote_session_id], references: [id])

  @@map("remote_checkin_logs")
}

model LeaveRequest {
  id               String    @id @default(uuid())
  user_id          String
  org_id           String
  leave_type       String    @db.VarChar(50)
  start_date       DateTime  @db.Date
  end_date         DateTime  @db.Date
  working_days     Float     // supports 0.5 for half-day
  is_half_day      Boolean   @default(false)
  half_day_period  String?   @db.VarChar(20) // 'morning' | 'afternoon'
  leave_start_time String?   @db.VarChar(10) // optional HH:MM for mid-shift leave
  leave_end_time   String?   @db.VarChar(10) // optional HH:MM for mid-shift leave
  reason           String?
  status           String    @default("pending")
  reviewed_by      String?
  rejection_reason String?
  created_at       DateTime  @default(now())
  reviewed_at      DateTime?

  user     User         @relation(fields: [user_id], references: [id])
  org      Organisation @relation(fields: [org_id], references: [id])
  reviewer User?        @relation("LeaveReviewer", fields: [reviewed_by], references: [id])

  @@map("leave_requests")
}

model LeaveBalance {
  id         String   @id @default(uuid())
  user_id    String
  org_id     String
  leave_type String   @db.VarChar(50)
  year       Int
  total_days Int
  used_days  Int      @default(0)
  updated_at DateTime @default(now()) @updatedAt

  user User         @relation(fields: [user_id], references: [id])
  org  Organisation @relation(fields: [org_id], references: [id])

  @@unique([user_id, leave_type, year])
  @@map("leave_balances")
}

model Shift {
  id           String    @id @default(uuid())
  org_id       String
  name         String    @db.VarChar(100)
  start_time   String    @db.VarChar(10)
  end_time     String    @db.VarChar(10)
  color        String    @default("#1D4ED8") @db.VarChar(20)
  active_days  Int[]
  is_published Boolean   @default(false)
  is_org_wide  Boolean   @default(false)
  is_default   Boolean   @default(false)
  created_by   String?
  created_at   DateTime  @default(now())

  overtime_multiplier           Decimal  @default(1.5) @db.Decimal(4, 2)
  min_rest_hours                Int      @default(11)
  late_tolerance_mins           Int      @default(15)
  early_checkout_tolerance_mins Int      @default(15)
  auto_checkout                 Boolean  @default(true)
  auto_checkout_buffer_mins     Int      @default(30)
  overtime_enabled              Boolean  @default(false)
  overtime_requires_approval    Boolean  @default(true)
  extra_time_label              String   @default("Extra office time") @db.VarChar(100)

  org                Organisation       @relation(fields: [org_id], references: [id])
  assignments        ShiftAssignment[]
  attendance_records AttendanceRecord[]
  breaks             ShiftBreak[]

  @@map("shifts")
}

model ShiftBreak {
  id               String  @id @default(uuid())
  shift_id         String
  name             String  @db.VarChar(100)
  break_kind       String  @default("fixed") @db.VarChar(20)
  break_minutes    Int
  is_paid          Boolean @default(false)
  after_minutes    Int
  break_start_time String? @db.VarChar(10)
  break_end_time   String? @db.VarChar(10)
  allowed_count_per_shift Int @default(1)
  paid_within_limit       Boolean @default(true)
  deduct_extra_time       Boolean @default(true)
  allow_extra_breaks      Boolean @default(true)
  applies_days            Int[] @default([])
  exception_dates         String[] @default([])
  // Auto-start: fixed breaks only
  auto_start              Boolean @default(false)
  reminder_after_mins     Int     @default(30)
  deduct_if_skipped       Boolean @default(true)

  shift         Shift         @relation(fields: [shift_id], references: [id], onDelete: Cascade)
  break_records BreakRecord[]

  @@map("shift_breaks")
}

model ShiftAssignment {
  id         String   @id @default(uuid())
  shift_id   String
  user_id    String
  date       DateTime @db.Date
  created_at DateTime @default(now())

  shift             Shift      @relation(fields: [shift_id], references: [id])
  user              User       @relation(fields: [user_id], references: [id])
  swap_as_requester ShiftSwap? @relation("RequesterAssignment")
  swap_as_target    ShiftSwap? @relation("TargetAssignment")

  @@unique([user_id, date])
  @@map("shift_assignments")
}

model ShiftSwap {
  id                   String   @id @default(uuid())
  requester_id         String
  target_id            String
  requester_assign_id  String   @unique
  target_assign_id     String   @unique
  status               String   @default("pending")
  reason               String?
  manager_id           String?
  rejection_reason     String?
  created_at           DateTime @default(now())

  requester            User            @relation("SwapRequester", fields: [requester_id], references: [id])
  target               User            @relation("SwapTarget", fields: [target_id], references: [id])
  requester_assignment ShiftAssignment @relation("RequesterAssignment", fields: [requester_assign_id], references: [id])
  target_assignment    ShiftAssignment @relation("TargetAssignment", fields: [target_assign_id], references: [id])

  @@map("shift_swaps")
}

model OvertimeRequest {
  id                String   @id @default(uuid())
  attendance_id     String   @unique
  user_id           String
  org_id            String
  requested_minutes Int
  reason            String?
  status            String   @default("pending") @db.VarChar(20)
  reviewed_by       String?
  reviewed_at       DateTime?
  rejection_reason  String?
  created_at        DateTime @default(now())

  attendance AttendanceRecord @relation(fields: [attendance_id], references: [id], onDelete: Cascade)
  user       User             @relation(fields: [user_id], references: [id])
  org        Organisation     @relation(fields: [org_id], references: [id])

  @@map("overtime_requests")
}

model PayrollRecord {
  id                String    @id @default(uuid())
  user_id           String
  org_id            String
  period_month      Int
  period_year       Int
  regular_hours     Decimal   @db.Decimal(6, 2)
  overtime_hours    Decimal   @default(0) @db.Decimal(6, 2)
  hourly_rate       Decimal   @db.Decimal(10, 2)
  base_pay          Decimal   @db.Decimal(12, 2)
  overtime_pay      Decimal   @default(0) @db.Decimal(12, 2)
  unpaid_deduction  Decimal   @default(0) @db.Decimal(12, 2)
  manual_adjustment Decimal   @default(0) @db.Decimal(12, 2)
  adjustment_reason String?
  gross_pay         Decimal   @db.Decimal(12, 2)
  tax_deduction     Decimal   @default(0) @db.Decimal(12, 2)
  pension_deduction Decimal   @default(0) @db.Decimal(12, 2)
  net_pay           Decimal   @default(0) @db.Decimal(12, 2)
  status            String    @default("draft")
  is_incomplete     Boolean   @default(false)
  payslip_url       String?
  processed_at      DateTime?
  processed_by      String?
  created_at        DateTime  @default(now())

  user      User         @relation(fields: [user_id], references: [id])
  org       Organisation @relation(fields: [org_id], references: [id])
  processor User?        @relation("PayrollProcessor", fields: [processed_by], references: [id])

  @@unique([user_id, period_month, period_year])
  @@map("payroll_records")
}

model OvertimeRule {
  id              String   @id @default(uuid())
  org_id          String
  name            String   @db.VarChar(100)
  rule_type       String   @db.VarChar(20)  // "daily" | "weekly" | "seventh_day"
  threshold_hours Decimal  @db.Decimal(5, 2)
  multiplier      Decimal  @db.Decimal(4, 2)
  priority        Int      @default(1)
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())

  org Organisation @relation(fields: [org_id], references: [id])

  @@map("overtime_rules")
}

model PerformanceReview {
  id               String    @id @default(uuid())
  user_id          String
  reviewer_id      String?
  org_id           String
  period_month     Int
  period_year      Int
  manager_rating   Int?
  attendance_score Decimal?  @db.Decimal(5, 2)
  overall_score    Decimal?  @db.Decimal(5, 2)
  notes            String?   @db.Text
  submitted_at     DateTime?
  created_at       DateTime  @default(now())

  user     User              @relation("ReviewSubject", fields: [user_id], references: [id])
  reviewer User?             @relation("ReviewSubmitter", fields: [reviewer_id], references: [id])
  org      Organisation      @relation(fields: [org_id], references: [id])
  goals    PerformanceGoal[]

  @@unique([user_id, period_month, period_year])
  @@map("performance_reviews")
}

model PerformanceGoal {
  id          String    @id @default(uuid())
  review_id   String
  user_id     String
  title       String    @db.VarChar(255)
  description String?   @db.Text
  weight      Int
  target_date DateTime? @db.Date
  completion  Int       @default(0)
  created_at  DateTime  @default(now())

  review PerformanceReview @relation(fields: [review_id], references: [id])
  user   User              @relation(fields: [user_id], references: [id])

  @@map("performance_goals")
}

model WhatsappLog {
  id             String    @id @default(uuid())
  org_id         String
  event_type     String    @db.VarChar(50)
  recipient_type String    @db.VarChar(20)
  recipient_id   String    @db.VarChar(255)
  message_body   String    @db.Text
  status         String    @default("pending")
  attempts       Int       @default(0)
  sent_at        DateTime?
  created_at     DateTime  @default(now())

  org Organisation @relation(fields: [org_id], references: [id])

  @@map("whatsapp_notification_logs")
}


model InAppNotification {
  id          String    @id @default(uuid())
  user_id     String
  org_id      String
  type        String    @db.VarChar(50)
  title       String    @db.VarChar(255)
  body        String    @db.Text
  action_type String?   @db.VarChar(50)
  action_id   String?   @db.VarChar(36)
  metadata    Json?     @default("{}")
  read_at     DateTime?
  created_at  DateTime  @default(now())

  user User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  org  Organisation @relation(fields: [org_id], references: [id], onDelete: Cascade)

  @@index([user_id, read_at])
  @@index([user_id, created_at(sort: Desc)])
  @@map("in_app_notifications")
}

// Employee submits an advance notice of late arrival before their shift.
// The scheduler checks this before alerting the manager about lateness.
model LateArrivalNotice {
  id              String    @id @default(uuid())
  user_id         String
  org_id          String
  date            DateTime  @db.Date
  expected_time   String    @db.VarChar(10)   // HH:MM wall-clock — expected arrival
  reason          String    @db.Text
  status          String    @default("pending") @db.VarChar(20) // pending | acknowledged | cancelled
  acknowledged_by String?
  acknowledged_at DateTime?
  created_at      DateTime  @default(now())

  user              User               @relation(fields: [user_id], references: [id])
  org               Organisation       @relation(fields: [org_id], references: [id])
  attendance_records AttendanceRecord[]

  @@unique([user_id, date])
  @@map("late_arrival_notices")
}

model PlanDefinition {
  id            String  @id @db.VarChar(50)
  display_name  String  @db.VarChar(100)
  price_monthly Decimal @default(0) @db.Decimal(10, 2)
  price_annual  Decimal @default(0) @db.Decimal(10, 2)
  max_employees Int     @default(0)
  trial_days    Int     @default(14)
  features      Json    @default("{}")
  description   String? @db.Text
  highlight     Boolean @default(false)
  is_active     Boolean @default(true)
  sort_order    Int     @default(0)
  updated_at    DateTime @default(now()) @updatedAt

  @@map("plan_definitions")
}

// ─── Dynamic RBAC ─────────────────────────────────────
model Permission {
  key         String  @id @db.VarChar(100)
  module      String  @db.VarChar(50)
  description String? @db.Text

  org_role_permissions      OrgRolePermission[]
  user_permission_grants    UserPermissionGrant[]
  platform_role_permissions PlatformRolePermission[]

  @@map("permissions")
}

model OrgRole {
  id         String   @id @default(uuid())
  org_id     String
  name       String   @db.VarChar(100)
  slug       String   @db.VarChar(50)
  is_system  Boolean  @default(false)
  created_at DateTime @default(now())

  org         Organisation        @relation(fields: [org_id], references: [id], onDelete: Cascade)
  permissions OrgRolePermission[]
  users       UserOrgRole[]

  @@unique([org_id, slug])
  @@map("org_roles")
}

model OrgRolePermission {
  org_role_id    String
  permission_key String

  org_role   OrgRole    @relation(fields: [org_role_id], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permission_key], references: [key], onDelete: Cascade)

  @@id([org_role_id, permission_key])
  @@map("org_role_permissions")
}

model UserOrgRole {
  id          String   @id @default(uuid())
  user_id     String   @unique
  org_role_id String
  created_at  DateTime @default(now())

  user     User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  org_role OrgRole @relation(fields: [org_role_id], references: [id], onDelete: Cascade)

  @@map("user_org_roles")
}

model UserPermissionGrant {
  id             String   @id @default(uuid())
  user_id        String
  org_id         String
  permission_key String
  effect         String   @db.VarChar(10) // allow | deny
  created_at     DateTime @default(now())

  user       User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  org        Organisation @relation(fields: [org_id], references: [id], onDelete: Cascade)
  permission Permission   @relation(fields: [permission_key], references: [key], onDelete: Cascade)

  @@unique([user_id, permission_key])
  @@map("user_permission_grants")
}

model PlatformRole {
  slug        String  @id @db.VarChar(50)
  name        String  @db.VarChar(100)
  description String? @db.Text

  permissions PlatformRolePermission[]
  users       PlatformUserRole[]

  @@map("platform_roles")
}

model PlatformRolePermission {
  platform_role_slug String @db.VarChar(50)
  permission_key     String @db.VarChar(100)

  platform_role PlatformRole @relation(fields: [platform_role_slug], references: [slug], onDelete: Cascade)
  permission    Permission   @relation(fields: [permission_key], references: [key], onDelete: Cascade)

  @@id([platform_role_slug, permission_key])
  @@map("platform_role_permissions")
}

model PlatformUserRole {
  user_id            String
  platform_role_slug String
  created_at         DateTime @default(now())

  user          User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  platform_role PlatformRole @relation(fields: [platform_role_slug], references: [slug], onDelete: Cascade)

  @@id([user_id, platform_role_slug])
  @@map("platform_user_roles")
}

model BlogPost {
  id               String    @id @default(uuid())
  slug             String    @unique @db.VarChar(255)
  title            String    @db.VarChar(500)
  excerpt          String?   @db.Text
  content          String    @default("") @db.Text
  author_name      String    @default("Attenda Team") @db.VarChar(255)
  author_avatar    String?   @db.VarChar(500)
  cover_image      String?   @db.VarChar(500)
  tags             String[]  @default([])
  meta_title       String?   @db.VarChar(500)
  meta_description String?   @db.Text
  og_image         String?   @db.VarChar(500)
  is_published     Boolean   @default(false)
  published_at     DateTime?
  read_time_mins   Int?
  views            Int       @default(0)
  created_at       DateTime  @default(now())
  updated_at       DateTime  @default(now()) @updatedAt

  @@map("blog_posts")
}
